<template id="status-data-json">${safeStatusHtml}</template>
<template id="priority-data-json">${safePriorityHtml}</template>
<template id="weekday-data-json">${safeWeekdayHtml}</template>
<template id="monthly-data-json">${safeMonthlyHtml}</template>
<template id="categories-data-json">${safeCategoriesHtml}</template>
<template id="agents-data-json">${safeAgentsHtml}</template>
<template id="sectors-data-json">${safeSectorsHtml}</template>
<template id="sector-weekdays-data-json">${safeSectorWeekdaysHtml}</template>

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
(function () {
  var statusData = JSON.parse(document.getElementById('status-data-json').content.textContent || '[]');
  var priorityData = JSON.parse(document.getElementById('priority-data-json').content.textContent || '[]');
  var weekdayData = JSON.parse(document.getElementById('weekday-data-json').content.textContent || '[]');
  var monthlyData = JSON.parse(document.getElementById('monthly-data-json').content.textContent || '[]');
  var categoriesData = JSON.parse(document.getElementById('categories-data-json').content.textContent || '[]');
  var agentsData = JSON.parse(document.getElementById('agents-data-json').content.textContent || '[]');
  var sectorsData = JSON.parse(document.getElementById('sectors-data-json').content.textContent || '[]');
  var sectorWeekdaysData = JSON.parse(document.getElementById('sector-weekdays-data-json').content.textContent || '[]');

  var statusColors = {
    aberto:'#f59e0b', em_andamento:'#0d9488',
    pausa:'#f97316', aguardando_usuario:'#6366f1', resolvido:'#10b981', fechado:'#94a3b8'
  };
  var statusLabels = {
    aberto:'Aberto', em_andamento:'Em andamento',
    pausa:'Pausa', aguardando_usuario:'Aguardando usuário', resolvido:'Resolvido', fechado:'Fechado'
  };
  var priorityColors = { baixa:'#10b981', media:'#f59e0b', alta:'#ef4444', critica:'#7f1d1d' };
  var priorityLabels = { baixa:'Baixa', media:'Média', alta:'Alta', critica:'Crítica' };
  var weekdayLabels = ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb'];
  var blues = ['#2b6fbb','#1b5eaa','#123a6f','#3b82f6','#60a5fa','#93c5fd','#bfdbfe','#dbeafe'];

  function createVerticalGradient(ctx, area, startColor, endColor) {
    var gradient = ctx.createLinearGradient(0, area.bottom, 0, area.top);
    gradient.addColorStop(0, startColor);
    gradient.addColorStop(1, endColor);
    return gradient;
  }

  function createHorizontalGradient(ctx, area, startColor, endColor) {
    var gradient = ctx.createLinearGradient(area.left, 0, area.right, 0);
    gradient.addColorStop(0, startColor);
    gradient.addColorStop(1, endColor);
    return gradient;
  }

  var centerTextPlugin = {
    id: 'centerTextPlugin',
    afterDatasetsDraw: function(chart, args, pluginOptions) {
      if (chart.config.type !== 'doughnut') return;
      var meta = chart.getDatasetMeta(0);
      if (!meta || !meta.data || !meta.data.length) return;
      var ctx = chart.ctx;
      var x = meta.data[0].x;
      var y = meta.data[0].y;
      ctx.save();
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillStyle = '#123a6f';
      ctx.font = '700 12px Segoe UI';
      ctx.fillText(pluginOptions.label || 'Total', x, y - 10);
      ctx.font = '800 28px Segoe UI';
      ctx.fillText(String(pluginOptions.value || 0), x, y + 14);
      ctx.restore();
    }
  };

  var endLabelPlugin = {
    id: 'endLabelPlugin',
    afterDatasetsDraw: function(chart) {
      if (chart.config.type !== 'bar' || chart.options.indexAxis !== 'y') return;
      var ctx = chart.ctx;
      var meta = chart.getDatasetMeta(0);
      ctx.save();
      ctx.fillStyle = '#123a6f';
      ctx.font = '700 11px Segoe UI';
      meta.data.forEach(function(bar, index) {
        var value = chart.data.datasets[0].data[index];
        ctx.textAlign = 'left';
        ctx.textBaseline = 'middle';
        ctx.fillText(String(value), bar.x + 8, bar.y);
      });
      ctx.restore();
    }
  };

  Chart.register(centerTextPlugin, endLabelPlugin);

  Chart.defaults.font.family = "'Inter','Segoe UI',sans-serif";
  Chart.defaults.font.size   = 12;
  Chart.defaults.color       = '#64748b';
  Chart.defaults.animation.duration = 900;

  if (statusData.length) {
    new Chart(document.getElementById('chartStatus'), {
      type: 'doughnut',
      data: {
        labels: statusData.map(function(d){ return statusLabels[d.status] || d.status; }),
        datasets: [{ data: statusData.map(function(d){ return d.total; }),
          backgroundColor: statusData.map(function(d){ return statusColors[d.status] || '#cbd5e1'; }),
          borderWidth: 4, borderColor: '#f8fbff', hoverOffset: 8,
          borderRadius: 10 }]
      },
      options: { responsive: true, maintainAspectRatio: false, cutout: '72%',
        plugins: { legend: { position: 'bottom', labels: { padding: 14, boxWidth: 12 } },
          centerTextPlugin: { label: 'Total', value: statusData.reduce(function(sum, item){ return sum + item.total; }, 0) },
          tooltip: { callbacks: { label: function(ctx) {
            var tot = ctx.dataset.data.reduce(function(a,b){ return a+b; }, 0);
            return ' ' + ctx.label + ': ' + ctx.parsed + ' (' + Math.round(ctx.parsed/tot*100) + '%)';
          }}}}
      }
    });
  }

  if (priorityData.length) {
    new Chart(document.getElementById('chartPriority'), {
      type: 'polarArea',
      data: {
        labels: priorityData.map(function(d){ return priorityLabels[d.priority] || d.priority; }),
        datasets: [{ label: 'Chamados',
          data: priorityData.map(function(d){ return d.total; }),
