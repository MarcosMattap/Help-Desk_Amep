  (function renderSectorDaysSummary() {
    var container = document.getElementById('unitDaysSummary');
    if (!container) return;
    if (!sectorWeekdaysData.length) {
      container.innerHTML = '<p class="unit-days-empty">Sem dados de atendimento por setor no período.</p>';
      return;
    }

    var weekdayNames = ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sab'];
    var map = {};

    sectorWeekdaysData.forEach(function(item) {
      var setor = item.setor || 'Sem setor';
      var weekday = Number(item.weekday);
      var total = Number(item.total) || 0;
      if (!map[setor]) {
        map[setor] = [];
      }
      if (!Number.isNaN(weekday) && weekday >= 0 && weekday <= 6) {
        map[setor].push({
          weekday: weekday,
          label: weekdayNames[weekday],
          total: total
        });
      }
    });

    var setorRows = Object.keys(map).sort().map(function(setor) {
      var sortedDays = map[setor].sort(function(a, b) { return a.weekday - b.weekday; });
      var diasLabel = sortedDays.map(function(d) { return d.label + ' (' + d.total + ')'; }).join(', ');
      return '<tr><td>' + escapeHtml(setor) + '</td><td>' + escapeHtml(diasLabel || 'Sem dados') + '</td></tr>';
    }).join('');

    container.innerHTML =
      '<table class="unit-days-table">' +
      '<thead><tr><th>Setor</th><th>Dias com atendimento</th></tr></thead>' +
      '<tbody>' + setorRows + '</tbody>' +
      '</table>';
  })();
