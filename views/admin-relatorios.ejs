<%
  const escapeHtml = (str) => {
    if (str == null) return '';
    return String(str)
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#x27;');
  };
  const safeStatus     = JSON.stringify(statusData     || []);
  const safePriority   = JSON.stringify(priorityData   || []);
  const safeWeekday    = JSON.stringify(weekdayData    || []);
  const safeMonthly    = JSON.stringify(monthlyData    || []);
  const safeCategories = JSON.stringify(categoriesData || []);
  const safeAgents     = JSON.stringify(agentsData     || []);
  const safeSectors      = JSON.stringify(sectorsData      || []);
  const safeSectorWeekdays = JSON.stringify(sectorWeekdaysData || []);
  const safeStatusHtml = escapeHtml(safeStatus);
  const safePriorityHtml = escapeHtml(safePriority);
  const safeWeekdayHtml = escapeHtml(safeWeekday);
  const safeMonthlyHtml = escapeHtml(safeMonthly);
  const safeCategoriesHtml = escapeHtml(safeCategories);
  const safeAgentsHtml = escapeHtml(safeAgents);
  const safeSectorsHtml = escapeHtml(safeSectors);
  const safeSectorWeekdaysHtml = escapeHtml(safeSectorWeekdays);
  const normalize = (value) => String(value || "").trim().toLowerCase();
  const isDbConsoleAllowed = !!(
    currentUser &&
    currentUser.role === "admin" &&
    currentUser.operadora_id === null &&
    (normalize(currentUser.name) === "marcos pereira" || normalize(currentUser.email).includes("marcos.pereira"))
  );
  let countAbertos = 0, countAndamento = 0, countResolvidos = 0;
  const weekdayNames = ["Domingo", "Segunda-feira", "Terça-feira", "Quarta-feira", "Quinta-feira", "Sexta-feira", "Sábado"];
  const topWeekdayNumber = topWeekday && topWeekday.weekday != null ? Number(topWeekday.weekday) : null;
  const topWeekdayName = Number.isInteger(topWeekdayNumber) && topWeekdayNumber >= 0 && topWeekdayNumber < weekdayNames.length
    ? weekdayNames[topWeekdayNumber]
    : "Sem dados";
  const topWeekdayTotal = topWeekday && topWeekday.total != null ? Number(topWeekday.total) : 0;
  (statusData || []).forEach(row => {
    if (row.status === 'aberto')       countAbertos    += row.total;
    if (row.status === 'em_andamento' || row.status === 'pausa') countAndamento  += row.total;
    if (row.status === 'resolvido' || row.status === 'fechado') countResolvidos += row.total;
  });
  const avgTimeHtml = avgTime !== null
    ? '<div class="chart-card chart-card--highlight chart-card--highlight-compact"><div class="chart-card-highlight-wrap"><div><p class="chart-card-subtitle" style="margin:0 0 0.25rem">Tempo m&eacute;dio de resolu&ccedil;&atilde;o</p><div class="highlight-value">' + avgTime + 'h</div></div><div class="highlight-icon"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg></div></div></div>'
    : '';
%>
<%- include("layout", { title: "Relatórios — Help Desk", body: `

