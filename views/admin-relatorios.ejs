      radial-gradient(circle at 86% 12%, rgba(13,148,136,0.16), transparent 28%),
      linear-gradient(180deg, rgba(255,255,255,0.95), rgba(255,255,255,0));
    pointer-events: none;
    z-index: 0;
  }
  .rel-shell > * {
    position: relative;
    z-index: 1;
  }
