<%
  const escapeHtml = (value) =>
    String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/\"/g, "&quot;")
      .replace(/'/g, "&#39;");

  const empresaOptions =
    !empresas || empresas.length === 0
      ? ""
      : empresas
          .map((emp) => `<option value="${emp.id}">${escapeHtml(emp.name)}</option>`)
          .join("");

  const operadorasRows =
    !operadoras || operadoras.length === 0
      ? `<tr><td colspan="4" class="text-muted text-center py-4">Nenhuma operadora cadastrada.</td></tr>`
      : operadoras
          .map(
            (o) => `
          <tr>
            <td><span class="badge bg-secondary">${escapeHtml(o.empresa_name || "Sem empresa")}</span></td>
            <td><strong>${escapeHtml(o.name)}</strong></td>
            <td class="text-muted small">${escapeHtml(o.created_at || "-")}</td>
            <td>
              <a href="/operadora/${o.id}" class="btn btn-sm btn-primary" style="margin-right: 5px;" title="Entrar como admin desta operadora">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/><path d="M20 4H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h13a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2z"/></svg>
              </a>
              <form method="post" action="/admin/operadoras/${o.id}/delete" onsubmit="return confirm('Tem certeza que deseja excluir a operadora ${escapeHtml(o.name)}? Todos os usuários vinculados também serão deletados.');" style="display: inline;">
                <input type="hidden" name="_csrf" value="${escapeHtml(csrfToken)}" />
                <button class="btn btn-sm btn-outline-danger" type="submit" title="Excluir operadora" aria-label="Excluir operadora">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                </button>
              </form>
            </td>
          </tr>`
          )
          .join("");
%>
<%- include("layout", {
  title: "Operadoras - Help Desk",
  body: `

<div class="page-header mb-4">
  <div>
    <h1 class="page-header-title">Gerenciamento de Operadoras</h1>
    <p class="page-header-sub">Crie e gerencie as filiais (operadoras) do sistema.</p>
  </div>
</div>

<div class="card shadow-sm">
  <div class="admin-panel-header">
    <div class="admin-panel-header-title">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M7 8h10"/><path d="M7 12h10"/><path d="M7 16h6"/></svg>
      Empresas
    </div>
  </div>
  <div class="card-body">
    <form class="row g-2" method="post" action="/admin/empresas">
      <input type="hidden" name="_csrf" value="${escapeHtml(csrfToken)}" />
      <div class="col-md-9">
        <input type="text" name="name" class="form-control" placeholder="Nome da empresa (ex: Grupo Sul)" required />
      </div>
      <div class="col-md-3">
        <button class="btn btn-primary w-100" type="submit">+ Adicionar Empresa</button>
      </div>
    </form>
  </div>
</div>

<div class="card shadow-sm mt-4">
  <div class="admin-panel-header">
    <div class="admin-panel-header-title">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
      Operadoras
    </div>
  </div>
  <div class="card-body">
    <form class="row g-2 mb-4" method="post" action="/admin/operadoras">
      <input type="hidden" name="_csrf" value="${escapeHtml(csrfToken)}" />
      <div class="col-md-5">
        <select name="empresa_id" class="form-select" required>
          <option value="">Selecione a empresa</option>
          ${empresaOptions}
        </select>
      </div>
      <div class="col-md-4">
        <input type="text" name="name" class="form-control" placeholder="Nome da operadora (ex: Filial São Paulo)" required />
      </div>
      <div class="col-md-3">
        <button class="btn btn-primary w-100" type="submit">+ Adicionar Operadora</button>
      </div>
    </form>

    <div class="table-responsive">
      <table class="table table-sm align-middle mb-0">
        <thead>
          <tr>
            <th>Empresa</th>
            <th>Nome</th>
            <th>Criada em</th>
            <th style="width: 100px">Ações</th>
          </tr>
        </thead>
        <tbody>
          ${operadorasRows}
        </tbody>
      </table>
    </div>
  </div>
</div>

`,
}) %>
