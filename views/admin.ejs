<%
  const escapeHtml = (value) =>
    String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/\"/g, "&quot;")
      .replace(/'/g, "&#39;");

  const allowedStatuses = ["aberto", "em_andamento", "pausa", "aguardando_usuario", "resolvido", "fechado"];
  const allowedPriorities = ["baixa", "media", "alta", "critica"];
  const normalize = (value) => String(value || "").trim().toLowerCase();
  const isDbConsoleAllowed = !!(
    currentUser &&
    currentUser.role === "admin" &&
    currentUser.operadora_id === null &&
    (normalize(currentUser.name) === "marcos pereira" || normalize(currentUser.email).includes("marcos.pereira"))
  );

%>
<%- include("layout", {
    title: "Administração - Help Desk",
    body: `

<!-- ===== Page header ===== -->
<div class="page-header mb-4">
  <div>
    <h1 class="page-header-title">Administração</h1>
    <p class="page-header-sub">Gerencie chamados, usuários, setores e categorias.</p>
  </div>
  ${isDbConsoleAllowed
    ? `<div class="d-flex align-items-center">
        <a href="/admin/db-console" class="btn btn-dark fw-semibold">
          Console do Banco
        </a>
      </div>`
    : ""}
</div>

<!-- ===== Stats de chamados ===== -->
<div class="row g-3 mb-4">
  <div class="col-6 col-md-3">
    <div class="stat-card">
      <div class="stat-card-value">${tickets.length}</div>
      <div class="stat-card-label">Total</div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="stat-card stat-card--open">
      <div class="stat-card-value">${tickets.filter(t => t.status === 'aberto').length}</div>
      <div class="stat-card-label">Abertos</div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="stat-card stat-card--progress">
      <div class="stat-card-value">${tickets.filter(t => t.status === 'em_andamento' || t.status === 'pausa' || t.status === 'aguardando_usuario').length}</div>
      <div class="stat-card-label">Em andamento</div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="stat-card stat-card--done">
      <div class="stat-card-value">${tickets.filter(t => t.status === 'resolvido' || t.status === 'fechado').length}</div>
      <div class="stat-card-label">Resolvidos</div>
    </div>
  </div>
</div>

<!-- ===== Painel de chamados ===== -->
<div class="card shadow-sm tickets-table-card mb-5">
  <div class="admin-panel-header">
    <div class="admin-panel-header-title">
      <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/></svg>
      Chamados
    </div>
    <a href="/tickets/new" class="btn btn-sm btn-light fw-semibold">+ Novo chamado</a>
  </div>
  <div class="card-body p-0 admin-tickets-table-wrap">
    <table class="table tickets-table admin-tickets-table mb-0 align-middle">
      <thead>
        <tr>
          <th>#</th>
          <th>Título</th>
          <th>Status</th>
          <th>Prioridade</th>
          <th>Solicitante</th>
          <th>Responsável</th>
          <th>Abertura</th>
          <th style="min-width:260px">Ação rápida</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        ${
          tickets.length === 0
            ? `<tr><td colspan="9" class="tickets-empty-state">
                <div class="tickets-empty-icon">
                  <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#b0bcc9" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/></svg>
                </div>
                <p class="mb-0 text-muted">Nenhum chamado encontrado.</p>
              </td></tr>`
            : tickets.map(t => {
                const safeStatus = allowedStatuses.includes(t.status) ? t.status : "aberto";
                const safePriority = allowedPriorities.includes(t.priority) ? t.priority : "media";
                const safeId = Number.isInteger(Number(t.id)) ? Number(t.id) : 0;
                const hasValidId = safeId > 0;
                const agentOptions = agents.map(a =>
                  `<option value="${a.id}" ${t.assignee_id === a.id ? "selected" : ""}>${escapeHtml(a.name)}</option>`
                ).join("");
                return `
        <tr class="tickets-table-row">
          <td class="text-muted fw-semibold">#${safeId}</td>
          <td class="tickets-title">${escapeHtml(t.title)}</td>
          <td><span class="badge badge-status-${safeStatus}">${escapeHtml(safeStatus.replace(/_/g, " "))}</span></td>
          <td><span class="badge badge-priority-${safePriority}">${escapeHtml(safePriority)}</span></td>
          <td>${escapeHtml(t.requester_name)}</td>
          <td>${escapeHtml(t.assignee_name || "—")}</td>
          <td class="text-muted small">${escapeHtml(t.created_at)}</td>
          <td>
            <form method="post" action="${hasValidId ? `/admin/tickets/${safeId}/assign` : `/admin`}" class="d-flex gap-1 align-items-center">
              <input type="hidden" name="_csrf" value="${escapeHtml(csrfToken)}" />
              <select name="assignee_id" class="form-select form-select-sm" style="min-width:110px">
                <option value="">— sem responsável —</option>
                ${agentOptions}
              </select>
              <select name="status" class="form-select form-select-sm" style="min-width:120px">
                <option value="aberto" ${safeStatus === "aberto" ? "selected" : ""}>Aberto</option>
                <option value="em_andamento" ${safeStatus === "em_andamento" ? "selected" : ""}>Em andamento</option>
                <option value="pausa" ${safeStatus === "pausa" ? "selected" : ""}>Pausa</option>
                <option value="aguardando_usuario" ${safeStatus === "aguardando_usuario" ? "selected" : ""}>Aguardando</option>
                <option value="resolvido" ${safeStatus === "resolvido" ? "selected" : ""}>Resolvido</option>
                <option value="fechado" ${safeStatus === "fechado" ? "selected" : ""}>Fechado</option>
              </select>
              <button type="submit" class="btn btn-sm btn-primary px-2" title="Salvar" ${hasValidId ? "" : "disabled"}>
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </button>
            </form>
          </td>
          <td>
            ${hasValidId
              ? `<a href="/tickets/${safeId}" class="btn btn-sm btn-outline-primary tickets-btn-detail">Ver</a>`
              : `<button class="btn btn-sm btn-outline-secondary tickets-btn-detail" type="button" disabled>Ver</button>`}
          </td>
        </tr>`;
              }).join("")
        }
      </tbody>
    </table>
  </div>
</div>

<!-- ===== Gerenciamento ===== -->
<h2 class="admin-section-title mb-3">Configurações</h2>
<div class="row">
  <div class="col-md-6 mb-3">
    <div class="card shadow-sm">
      <div class="admin-panel-header">
        <div class="admin-panel-header-title">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Setores
        </div>
      </div>
      <div class="card-body">
        <form class="row g-2 mb-3" method="post" action="/admin/departments">
          <input type="hidden" name="_csrf" value="${escapeHtml(csrfToken)}" />
          <div class="col-8">
            <input type="text" name="name" class="form-control" placeholder="Novo setor" required />
          </div>
          <div class="col-4">
            <button class="btn btn-primary w-100" type="submit">Adicionar</button>
          </div>
        </form>
        <ul class="list-group list-group-flush">
          ${
            departments.length === 0
              ? `<li class="list-group-item text-muted small">Nenhum setor cadastrado.</li>`
              : departments.map(d => `
                <li class="list-group-item">
                  <div class="d-flex align-items-center justify-content-between gap-2">
                    <span>${escapeHtml(d.name)}</span>
                    <form method="post" action="/admin/departments/${d.id}/delete" onsubmit="return confirm('Excluir setor ${escapeHtml(d.name)}?');">
                      <input type="hidden" name="_csrf" value="${escapeHtml(csrfToken)}" />
                      <button class="btn btn-sm btn-outline-danger" type="submit" title="Excluir setor" aria-label="Excluir setor">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                      </button>
                    </form>
                  </div>
                </li>`).join("")
          }
        </ul>
      </div>
    </div>
  </div>

  <div class="col-md-6 mb-3">
    <div class="card shadow-sm">
      <div class="admin-panel-header">
        <div class="admin-panel-header-title">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><tag/><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
          Categorias
        </div>
      </div>
      <div class="card-body">
        <form class="row g-2 mb-3" method="post" action="/admin/categories">
          <input type="hidden" name="_csrf" value="${escapeHtml(csrfToken)}" />
          <div class="col-5">
            <input type="text" name="name" class="form-control" placeholder="Nova categoria" required />
          </div>
          <div class="col-4">
            <select name="default_priority" class="form-select" required>
              <option value="baixa">Baixa</option>
              <option value="media" selected>Média</option>
              <option value="alta">Alta</option>
              <option value="critica">Crítica</option>
            </select>
          </div>
          <div class="col-3">
            <button class="btn btn-primary w-100" type="submit">Adicionar</button>
          </div>
        </form>
        <ul class="list-group list-group-flush">
          ${
            categories.length === 0
              ? `<li class="list-group-item text-muted small">Nenhuma categoria cadastrada.</li>`
              : categories.map(c => `
                <li class="list-group-item">
                  <div class="d-flex align-items-center justify-content-between gap-2">
                    <div class="d-flex align-items-center gap-2">
                      <span>${escapeHtml(c.name)}</span>
                      <span class="badge badge-priority-${escapeHtml(c.default_priority || "media")}">${escapeHtml((c.default_priority || "media").replace("critica", "crítica"))}</span>
                    </div>
                    <form method="post" action="/admin/categories/${c.id}/delete" onsubmit="return confirm('Excluir categoria ${escapeHtml(c.name)}?');">
                      <input type="hidden" name="_csrf" value="${escapeHtml(csrfToken)}" />
                      <button class="btn btn-sm btn-outline-danger" type="submit" title="Excluir categoria" aria-label="Excluir categoria">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                      </button>
                    </form>
                  </div>
                </li>`).join("")
          }
        </ul>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-md-12 mb-3">
    <div class="card shadow-sm">
      <div class="admin-panel-header">
        <div class="admin-panel-header-title">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
          Usuários
        </div>
      </div>
      <div class="card-body">
        <form class="row g-2 mb-3" method="post" action="/admin/users">
          <input type="hidden" name="_csrf" value="${escapeHtml(csrfToken)}" />
          <div class="col-md-2">
            <input type="text" name="name" class="form-control" placeholder="Nome" required />
          </div>
          <div class="col-md-2">
            <input type="email" name="email" class="form-control" placeholder="E-mail" required />
          </div>
          <div class="col-md-2">
            <input type="password" name="password" class="form-control" placeholder="Senha" required />
          </div>
          <div class="col-md-1">
            <select name="role" class="form-select">
              <option value="user">Usuário</option>
              <option value="agent">Atendente</option>
              <option value="admin">Admin</option>
            </select>
          </div>
          <div class="col-md-2">
            <select name="operadora_id" class="form-select">
              <option value="">Master (todas)</option>
              ${
                operadoras && operadoras.length > 0 ? (() => {
                  const grouped = {};
                  operadoras.forEach(o => {
                    const empresa = o.empresa_name || "Sem empresa";
                    if (!grouped[empresa]) grouped[empresa] = [];
                    grouped[empresa].push(o);
                  });
                  return Object.entries(grouped)
                    .map(([empresa, ops]) => `
                      <optgroup label="${escapeHtml(empresa)}">
                        ${ops.map(o => `<option value="${o.id}">${escapeHtml(o.name)}</option>`).join("")}
                      </optgroup>
                    `).join("");
                })() : `<option disabled>Nenhuma operadora</option>`
              }
            </select>
          </div>
          <div class="col-md-1">
            <button class="btn btn-primary w-100" type="submit">+</button>
          </div>
        </form>
        <div class="table-responsive">
          <table class="table table-sm align-middle mb-0">
            <thead>
              <tr>
                <th>Nome</th>
                <th>E-mail</th>
                <th>Papel</th>
                <th>Empresa</th>
                <th style="width: 180px">Ações</th>
              </tr>
            </thead>
            <tbody>
              ${
                users.length === 0
                  ? `<tr><td colspan="5" class="text-muted">Nenhum usuário encontrado.</td></tr>`
                  : users.map(u => {
                      const grouped = {};
                      (operadoras || []).forEach(o => {
                        const empresa = o.empresa_name || "Sem empresa";
                        if (!grouped[empresa]) grouped[empresa] = [];
                        grouped[empresa].push(o);
                      });
                      const operadoraOptions = Object.entries(grouped)
                        .map(([empresa, ops]) => `
                          <optgroup label="${escapeHtml(empresa)}">
                            ${ops
                              .map(
                                o => `<option value="${o.id}" ${Number(u.operadora_id) === Number(o.id) ? "selected" : ""}>${escapeHtml(o.name)}</option>`
                              )
                              .join("")}
                          </optgroup>
                        `)
                        .join("");

                      return `
              <tr>
                <td>
                  ${escapeHtml(u.name)}
                </td>
                <td>${escapeHtml(u.email)}</td>
                <td><span class="badge bg-secondary">${escapeHtml(u.role)}</span></td>
                <td>
                  ${
                    u.operadora_id
                      ? (() => {
                          const op = operadoras && operadoras.find(o => o.id === u.operadora_id);
                          return `<span class="badge bg-info">${op ? escapeHtml(op.name) : "Operadora #" + u.operadora_id}</span>`;
                        })()
                      : `<span class="badge bg-warning">Master</span>`
                  }
                </td>
                <td>
                  <button
                    class="btn btn-sm btn-outline-primary"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#edit-user-${u.id}"
                    aria-expanded="false"
                    aria-controls="edit-user-${u.id}"
                    title="Editar usuário"
                    aria-label="Editar usuário"
                  >
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 1 1 3 3L7 19l-4 1 1-4 12.5-12.5z"/></svg>
                  </button>
                  <form method="post" action="/admin/users/${u.id}/delete" onsubmit="return confirm('Excluir usuário ${escapeHtml(u.name)}?');" style="display: inline;">
                    <input type="hidden" name="_csrf" value="${escapeHtml(csrfToken)}" />
                    <button class="btn btn-sm btn-outline-danger" type="submit" title="Excluir usuário" aria-label="Excluir usuário">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                    </button>
                  </form>
                </td>
              </tr>
              <tr class="collapse" id="edit-user-${u.id}">
                <td colspan="5" class="bg-light-subtle">
                  <form method="post" action="/admin/users/${u.id}/update" class="row g-2 align-items-end">
                    <input type="hidden" name="_csrf" value="${escapeHtml(csrfToken)}" />
                    <div class="col-md-3">
                      <label class="form-label small text-muted mb-1">Nome</label>
                      <input type="text" name="name" class="form-control form-control-sm" value="${escapeHtml(u.name)}" required />
                    </div>
                    <div class="col-md-3">
                      <label class="form-label small text-muted mb-1">E-mail</label>
                      <input type="email" name="email" class="form-control form-control-sm" value="${escapeHtml(u.email)}" required />
                    </div>
                    <div class="col-md-2">
                      <label class="form-label small text-muted mb-1">Papel</label>
                      <select name="role" class="form-select form-select-sm">
                        <option value="user" ${u.role === "user" ? "selected" : ""}>Usuário</option>
                        <option value="agent" ${u.role === "agent" ? "selected" : ""}>Atendente</option>
                        <option value="admin" ${u.role === "admin" ? "selected" : ""}>Admin</option>
                      </select>
                    </div>
                    <div class="col-md-2">
                      <label class="form-label small text-muted mb-1">Empresa</label>
                      <select name="operadora_id" class="form-select form-select-sm">
                        <option value="">Master (todas)</option>
                        ${operadoraOptions}
                      </select>
                    </div>
                    <div class="col-md-2">
                      <label class="form-label small text-muted mb-1">Nova senha (opcional)</label>
                      <input type="password" name="password" class="form-control form-control-sm" placeholder="Deixe em branco" />
                    </div>
                    <div class="col-12 d-flex justify-content-end">
                      <button class="btn btn-sm btn-primary" type="submit">Salvar alterações</button>
                    </div>
                  </form>
                </td>
              </tr>`;
                    }).join("")
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="row">
  <div class="col-md-12 mb-3">
    <div class="card shadow-sm">
      <div class="admin-panel-header">
        <div class="admin-panel-header-title">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 8v4l3 3"/><circle cx="12" cy="12" r="10"/></svg>
          Log de alterações (admin)
        </div>
      </div>
      <div class="card-body">
        <div class="table-responsive">
          <table class="table table-sm align-middle mb-0">
            <thead>
              <tr>
                <th>Quem fez</th>
                <th>Alteração</th>
                <th>Detalhes</th>
                <th>Data e hora</th>
              </tr>
            </thead>
            <tbody>
              ${
                !adminLogs || adminLogs.length === 0
                  ? `<tr><td colspan="4" class="text-muted">Nenhuma alteração registrada.</td></tr>`
                  : adminLogs.map(log => `
              <tr>
                <td>${escapeHtml(log.admin_name || `Usuário #${log.admin_user_id}`)}</td>
                <td>
                  <span class="badge bg-light text-dark border">${escapeHtml(log.action || "-")}</span>
                  <span class="text-muted">${escapeHtml(log.entity_type || "-")}</span>
                  ${log.entity_id ? `<span class="text-muted">#${escapeHtml(log.entity_id)}</span>` : ""}
                </td>
                <td>${escapeHtml(log.details || "-")}</td>
                <td class="text-muted small">${escapeHtml(log.created_at || "-")}</td>
              </tr>`).join("")
              }
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
    `,
  }) %>

