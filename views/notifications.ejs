<%
  const escapeHtml = (value) =>
    String(value ?? "")
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/\"/g, "&quot;")
      .replace(/'/g, "&#39;");
%>
<%- include("layout", {
    title: "Notificações - Help Desk",
    body: `
<div class="page-header mb-4">
  <div>
    <h1 class="page-header-title">Notificações</h1>
    <p class="page-header-sub">Últimas atualizações dos seus chamados</p>
  </div>
</div>

${notifications.length === 0 ? `
  <div class="tickets-table-card card shadow-sm">
    <div class="tickets-empty-state">
      <div class="tickets-empty-icon">
        <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="#9ab4cc" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
          <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
        </svg>
      </div>
      <p class="text-muted mt-2 mb-0">Nenhuma notificação por enquanto.</p>
    </div>
  </div>
` : `
  <div class="card shadow-sm" style="border-radius:14px;overflow:hidden;border:1px solid #e0e8f4;">
    <div class="admin-panel-header">
      <span class="admin-panel-header-title">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>
        ${notifications.length} notifica${notifications.length === 1 ? 'ção' : 'ções'}
      </span>
    </div>
    <ul class="list-unstyled mb-0">
      ${notifications.map((notif, i) => `
        <li class="notif-list-item${notif.is_read ? '' : ' notif-list-item--unread'}"${i < notifications.length - 1 ? ' style="border-bottom:1px solid #edf2f8;"' : ''}>
          <div class="notif-list-icon${notif.type === 'new_ticket' ? ' notif-list-icon--admin' : ' notif-list-icon--user'}">
            ${notif.type === 'new_ticket'
              ? '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><line x1="12" y1="12" x2="12" y2="16"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>'
              : '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>'
            }
          </div>
          <div class="notif-list-body">
            <p class="notif-list-message">${escapeHtml(notif.message)}</p>
            <span class="notif-list-time">${escapeHtml(notif.created_at)}</span>
          </div>
          ${notif.ticket_id ? `<a href="/tickets/${notif.ticket_id}" class="btn btn-sm btn-outline-primary notif-list-action">Ver chamado</a>` : ''}
        </li>
      `).join('')}
    </ul>
  </div>
`}
    `
}) %>
